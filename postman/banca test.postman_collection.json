      "item": [
        {
          "name": "crear cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "    });\r",
                  "\r",
                  "const response = pm.response.json();\r",
                  "pm.expect(response.id).to.not.be.null;\r",
                  "\r",
                  "pm.test(\"Response body contiene todas las propiedades\", function () {\r",
                  "    pm.expect(response).to.have.property('id_cliente'),\r",
                  "    pm.expect(response).to.have.property('nombre'),\r",
                  "    pm.expect(response).to.have.property('ciudad')\r",
                  "});\r",
                  "\r",
                  "pm.environment.set('clienteId', response.id_cliente);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"nombre\": \"Juan Perez\",\r\n  \"ciudad\": \"Buenos Aires\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{local}}clientes",
